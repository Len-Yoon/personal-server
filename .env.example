# OpenAI / external APIs
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5-mini
ALADIN_TTB_KEY=

# Public HTTPS / Cloudflare
CADDY_EMAIL=
CLOUDFLARE_API_TOKEN=

# Admin passwords
DELETE_PASSWORD=
FILE_MANAGER_PASSWORD=
FILE_MANAGER_ACCESS_PASSWORD=
# Portfolio editor only. Use a different long random password in .env.
PORTFOLIO_ADMIN_PASSWORD=
# Optional; default is /data/files/.portfolio/portfolio.md
PORTFOLIO_CONTENT_PATH=

# Service URLs
PORTAL_HOME_URL=
NEWS_SERVICE_URL=https://news.len.pe.kr
YOUTUBE_MEMO_URL=https://memo.len.pe.kr
BOOK_MEMO_URL=https://books.len.pe.kr
SYSTEM_AGENT_URL=http://system-agent:8010
DEMO_MODE=

# Hostnames
FILES_HOSTNAME=file.len.pe.kr
ADMIN_HOSTNAME=admin.len.pe.kr

# File manager
FILE_STORAGE_PATH=/data/files
FILE_MANAGER_AUTH_REQUIRED=true
APP_ENV=production
FILE_MAX_UPLOAD_MB=50
FILE_BLOCKED_EXTENSIONS=app,bat,cmd,com,dll,dmg,exe,jar,js,msi,php,ps1,sh,vbs
FILE_ALLOWED_EXTENSIONS=

# Security logs and news archive
SECURITY_LOG_PATH=
SECURITY_LOG_TIMEZONE=Asia/Seoul
SECURITY_LOG_RETENTION_DAYS=30
NEWS_ARCHIVE_PATH=/data/crawler-worker/news_archive.json
NEWS_RETENTION_DAYS=7
NEWS_REFRESH_INTERVAL_SECONDS=300

# Authentication rate limit
AUTH_RATE_LIMIT_MAX_FAILURES=
AUTH_RATE_LIMIT_WINDOW_SECONDS=

# Backups and host metrics
DATA_ROOT=
BACKUP_PATH=
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_FILES=false
BACKUP_STALE_SECONDS=172800
HOST_METRICS_PATH=
HOST_METRICS_STALE_SECONDS=900
