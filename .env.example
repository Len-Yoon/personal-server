# External APIs
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5-mini
ALADIN_TTB_KEY=

# Caddy + Cloudflare public HTTPS
# Caddy contact email
CADDY_EMAIL=
# Cloudflare API token for DNS challenge
CLOUDFLARE_API_TOKEN=

# Admin passwords
DELETE_PASSWORD=
FILE_MANAGER_PASSWORD=

# Portal links
PORTAL_HOME_URL=https://len.pe.kr
NEWS_SERVICE_URL=https://news.len.pe.kr
YOUTUBE_MEMO_URL=https://memo.len.pe.kr
BOOK_MEMO_URL=https://books.len.pe.kr
SYSTEM_AGENT_URL=http://system-agent:8010
DEMO_MODE=

# Investing.com -> Obsidian daily importer
OBSIDIAN_VAULT_PATH=
OBSIDIAN_NEWS_DIR=뉴스/Investing
INVESTING_NEWS_URL=https://news.google.com/rss/search?q=site%3Akr.investing.com%2Fnews&hl=ko&gl=KR&ceid=KR%3Ako
INVESTING_NEWS_LIMIT=50
INVESTING_NEWS_TIMEZONE=Asia/Seoul

# Portal hostnames
FILES_HOSTNAME=file.len.pe.kr
ADMIN_HOSTNAME=admin.len.pe.kr

# File manager
FILE_STORAGE_PATH=/data/files
FILE_MANAGER_AUTH_REQUIRED=true
APP_ENV=production
FILE_MAX_UPLOAD_MB=50
FILE_BLOCKED_EXTENSIONS=app,bat,cmd,com,dll,dmg,exe,jar,js,msi,php,ps1,sh,vbs

# Security logs
SECURITY_LOG_PATH=/app/data/logs/security-events.txt
SECURITY_LOG_TIMEZONE=Asia/Seoul
SECURITY_LOG_RETENTION_DAYS=30
OBSIDIAN_NEWS_RETENTION_DAYS=30
AUTH_RATE_LIMIT_MAX_FAILURES=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
